---
---

<section class="py-20 bg-neo-light">
  <div class="max-w-7xl mx-auto px-6">
    <div class="relative bg-gradient-to-br from-neo-primary to-neo-secondary rounded-2xl overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-1/3 w-48 h-48 bg-white/5 rounded-full blur-2xl"></div>

      <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-8 items-center p-8 md:p-12 lg:p-14">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-white leading-snug">
            Téléchargez l'application Neo
          </h2>
          <p class="mt-4 text-white/85 text-sm md:text-base leading-relaxed max-w-md">
            Disponible sur iOS et Android pour un accès fluide à tout moment. Gérez vos finances depuis votre poche.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a href="#" class="inline-flex items-center gap-3 bg-black/30 backdrop-blur-sm border border-white/20 rounded-xl px-5 py-3 hover:bg-black/50 transition-colors">
              <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              <div class="text-left">
                <p class="text-white/70 text-[10px] leading-none">Télécharger sur</p>
                <p class="text-white font-semibold text-sm leading-tight mt-0.5">App Store</p>
              </div>
            </a>
            <a href="#" class="inline-flex items-center gap-3 bg-black/30 backdrop-blur-sm border border-white/20 rounded-xl px-5 py-3 hover:bg-black/50 transition-colors">
              <svg class="w-7 h-7 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 010 1.38l-2.302 2.302L15.196 12l2.502-2.492zM5.864 2.658L16.8 9.49l-2.302 2.302-8.634-8.634z"/></svg>
              <div class="text-left">
                <p class="text-white/70 text-[10px] leading-none">Disponible sur</p>
                <p class="text-white font-semibold text-sm leading-tight mt-0.5">Google Play</p>
              </div>
            </a>
          </div>
        </div>

        <div class="hidden md:flex justify-center">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/20 text-center">
            <div class="w-36 h-36 mx-auto bg-white rounded-xl flex items-center justify-center">
              <svg class="w-24 h-24 text-neo-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <rect x="3" y="14" width="7" height="7" rx="1" />
                <rect x="14" y="14" width="4" height="4" rx="0.5" />
                <rect x="19" y="19" width="2" height="2" rx="0.25" />
                <rect x="14" y="19" width="2" height="2" rx="0.25" />
                <rect x="19" y="14" width="2" height="2" rx="0.25" />
              </svg>
            </div>
            <p class="mt-4 text-white/80 text-sm">Scannez le code QR</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
