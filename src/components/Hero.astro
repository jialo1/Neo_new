---
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-20">
  <div class="absolute inset-0 bg-gradient-to-br from-neo-primary/5 via-white to-neo-secondary/10"></div>

  <div class="absolute top-20 right-0 w-[600px] h-[600px] bg-neo-secondary/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-neo-primary/10 rounded-full blur-3xl"></div>

  <div class="relative w-full max-w-7xl mx-auto px-6 py-12 md:py-16 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-8 xl:gap-12 items-center text-left">
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-neo-primary/10 rounded-full mb-8">
          <span class="w-2 h-2 bg-neo-secondary rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-neo-primary">Nouvelle génération de services financiers</span>
        </div>

        <h1 class="text-3xl md:text-4xl font-extrabold leading-tight tracking-tight max-w-xl lg:max-w-2xl">
          L'argent,
          <span class="bg-gradient-to-r from-neo-primary to-neo-secondary bg-clip-text text-transparent">
            réinventé
          </span>
          pour vous
        </h1>

        <p class="mt-6 text-base md:text-lg text-neo-gray max-w-xl leading-relaxed">
          Paiements instantanés, transferts sans frontières et gestion financière intelligente.
          Neo simplifie votre quotidien financier.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-start justify-start gap-4">
          <a href="#contact" class="group px-8 py-4 bg-neo-primary text-white font-semibold rounded-full hover:bg-neo-secondary transition-all duration-300 shadow-lg shadow-neo-primary/25 hover:shadow-neo-secondary/25">
            Ouvrir un compte gratuit
            <span class="inline-block ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
          </a>
          <a href="#how-it-works" class="px-8 py-4 border-2 border-neo-light text-neo-black font-semibold rounded-full hover:border-neo-primary hover:text-neo-primary transition-all duration-300">
            Découvrir Neo
          </a>
        </div>

        <div class="mt-12 flex flex-wrap items-center justify-start gap-6 sm:gap-8 text-sm text-neo-gray">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-neo-secondary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <span>Sécurisé & certifié</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-neo-secondary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span>Transferts instantanés</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-neo-secondary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>0 frais cachés</span>
          </div>
        </div>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <div class="relative w-full max-w-[420px] lg:max-w-none">
          <div class="absolute inset-0 bg-gradient-to-t from-neo-secondary/15 to-transparent rounded-3xl blur-2xl scale-95 translate-y-4" aria-hidden="true"></div>
          <img
            src="/images/hero-woman.png"
            alt="Cliente utilisant l'application Neo sur smartphone"
            class="relative w-full h-auto max-h-[min(520px,65vh)] lg:max-h-[min(580px,75vh)] object-contain object-bottom"
            width="800"
            height="900"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>

    <div class="mt-14 lg:mt-16 relative w-full">
      <div class="bg-gradient-to-r from-neo-primary to-neo-secondary rounded-2xl p-[1px]">
        <div class="bg-neo-dark rounded-[15px] px-8 py-5 md:px-12 md:py-6">
          <div class="grid grid-cols-3 gap-6 text-center text-white">
            <div>
              <p class="text-xl md:text-2xl font-bold">500K+</p>
              <p class="text-xs text-gray-400 mt-0.5">Utilisateurs actifs</p>
            </div>
            <div>
              <p class="text-xl md:text-2xl font-bold">50+</p>
              <p class="text-xs text-gray-400 mt-0.5">Pays couverts</p>
            </div>
            <div>
              <p class="text-xl md:text-2xl font-bold">99.9%</p>
              <p class="text-xs text-gray-400 mt-0.5">Disponibilité</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
