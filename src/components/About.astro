---
interface Props {
  variant?: 'default' | 'page';
}

const { variant = 'default' } = Astro.props;
const sectionPadding = variant === 'page' ? 'pt-8 pb-24' : 'py-24';
---

<section id="about" class:list={[sectionPadding, 'bg-white']}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <div class="bg-gradient-to-br from-neo-primary to-neo-secondary rounded-3xl p-1">
          <div class="bg-white rounded-[22px] p-10">
            <div class="space-y-8">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-neo-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-neo-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 003 12c0-1.605.42-3.113 1.157-4.418"/></svg>
                </div>
                <div>
                  <p class="text-2xl font-bold text-neo-black">50+</p>
                  <p class="text-sm text-neo-gray">Pays desservis</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-neo-secondary/10 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-neo-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
                </div>
                <div>
                  <p class="text-2xl font-bold text-neo-black">200+</p>
                  <p class="text-sm text-neo-gray">Collaborateurs</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-neo-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-6 h-6 text-neo-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <p class="text-2xl font-bold text-neo-black">2Md+</p>
                  <p class="text-sm text-neo-gray">Transactions traitées</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div>
        <span class="text-sm font-semibold text-neo-secondary uppercase tracking-wider">À propos</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold text-neo-black leading-tight">
          Une mission : rendre la <span class="text-neo-primary">finance accessible</span> à tous
        </h2>
        <p class="mt-6 text-neo-gray text-base md:text-lg leading-relaxed">
          Née de la conviction que les services financiers doivent être simples, transparents et accessibles, Neo repense la façon dont vous interagissez avec votre argent.
        </p>
        <p class="mt-4 text-neo-gray text-base md:text-lg leading-relaxed">
          Notre équipe de passionnés combine expertise technologique et connaissance approfondie du secteur financier pour créer des produits qui font la différence dans votre quotidien.
        </p>
        <a href="#contact" class="inline-flex items-center gap-2 mt-8 text-neo-primary font-semibold hover:text-neo-secondary transition-colors">
          En savoir plus sur Neo
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
