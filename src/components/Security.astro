---
const certifications = [
  { label: "PCI DSS", description: "Norme de sécurité des données bancaires" },
  { label: "RGPD", description: "Protection des données personnelles" },
  { label: "ISO 27001", description: "Gestion de la sécurité de l'information" },
  { label: "3D Secure", description: "Authentification renforcée des paiements" }
];

interface Props {
  variant?: 'default' | 'page';
}

const { variant = 'default' } = Astro.props;
const sectionPadding = variant === 'page' ? 'pt-8 pb-24' : 'py-24';
---

<section id="security" class:list={[sectionPadding, 'bg-neo-black text-white overflow-hidden relative']}>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-neo-primary/20 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-neo-secondary/10 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="text-sm font-semibold text-neo-secondary uppercase tracking-wider">Sécurité</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold leading-tight">
          Votre argent est en <span class="bg-gradient-to-r from-neo-secondary to-neo-primary bg-clip-text text-transparent">sécurité totale</span>
        </h2>
        <p class="mt-6 text-gray-400 text-base md:text-lg leading-relaxed">
          Nous utilisons les technologies de chiffrement les plus avancées pour protéger vos données et vos transactions. Chaque opération est surveillée par notre système anti-fraude alimenté par l'IA.
        </p>

        <ul class="mt-8 space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-neo-secondary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-gray-300">Chiffrement AES-256 de bout en bout</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-neo-secondary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-gray-300">Authentification biométrique (empreinte, Face ID)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-neo-secondary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-gray-300">Surveillance 24/7 par intelligence artificielle</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-neo-secondary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-gray-300">Blocage instantané de votre carte en un tap</span>
          </li>
        </ul>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {certifications.map((cert) => (
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
            <div class="w-12 h-12 bg-gradient-to-br from-neo-primary to-neo-secondary rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
            </div>
            <h4 class="text-base font-bold text-white">{cert.label}</h4>
            <p class="mt-1 text-sm text-gray-400">{cert.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
