---
const features = [
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>`,
    title: "Virement bancaire",
    description: "Virez de l'argent de l'application vers votre compte bancaire en toute sécurité. Traitement rapide et fiable.",
    badges: ["Vers compte bancaire", "Traitement rapide", "Sécurisé et fiable"]
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`,
    title: "Transfert instantané",
    description: "Envoyez de l'argent instantanément à vos proches. Rapide, sécurisé et sans frais cachés.",
    badges: ["Transfert instantané", "Sans frais cachés", "Sécurisé 24h/24"]
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 14.25l6-6m4.5-3.493V21.75l-3.75-1.5-3.75 1.5-3.75-1.5-3.75 1.5V4.757c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0c1.1.128 1.907 1.077 1.907 2.185zM9.75 9h.008v.008H9.75V9zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 4.5h.008v.008h-.008V13.5zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg>`,
    title: "Paiement de factures",
    description: "Réglez toutes vos factures en quelques clics. Électricité, eau, internet, télévision et bien plus encore.",
    badges: ["Paiement instantané", "Reçu électronique", "Sécurisé 24h/24"]
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>`,
    title: "Analyse des données",
    description: "Gardez le contrôle sur vos finances en un coup d'œil. Suivez vos dépenses, revenus et habitudes en temps réel.",
    badges: ["Historique détaillé", "Graphiques interactifs", "Mises à jour en temps réel"]
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg>`,
    title: "Carte virtuelle",
    description: "Gérez votre carte virtuelle Neo depuis votre smartphone. Paiements en ligne sécurisés, contrôle total de vos dépenses.",
    badges: ["Paiements en ligne", "Contrôle total", "Activation instantanée"]
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Services bancaires sécurisés",
    description: "Vos transactions sont protégées par des standards de sécurité élevés, avec cryptage de bout en bout et authentification multifacteur.",
    badges: ["Chiffrement AES-256", "Authentification 2FA", "Conformité bancaire"]
  }
];

interface Props {
  variant?: 'default' | 'page';
}

const { variant = 'default' } = Astro.props;
const sectionPadding = variant === 'page' ? 'pt-8 pb-24' : 'py-24';
---

<section id="solutions" class:list={[sectionPadding, 'bg-neo-light']}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-semibold text-neo-secondary uppercase tracking-wider">Nos services</span>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-neo-black">
        Des solutions complètes pour tous vos <span class="text-neo-primary">besoins financiers</span>
      </h2>
      <p class="mt-4 text-neo-gray text-base md:text-lg">
        Des fonctionnalités pensées pour vous offrir une gestion fluide, intuitive et complète de vos finances.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 border border-transparent hover:border-neo-secondary/30">
          <div class="w-14 h-14 bg-neo-primary/10 rounded-xl flex items-center justify-center text-neo-primary group-hover:bg-neo-primary group-hover:text-white transition-all duration-300">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="mt-6 text-lg font-bold text-neo-black">{feature.title}</h3>
          <p class="mt-3 text-neo-gray leading-relaxed text-sm">{feature.description}</p>
          {feature.badges && (
            <div class="mt-4 flex flex-wrap gap-2">
              {feature.badges.map((badge: string) => (
                <span class="inline-flex items-center gap-1 text-xs text-neo-primary bg-neo-primary/8 px-2.5 py-1 rounded-full">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  {badge}
                </span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
