---
const features = [
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/></svg>`,
    title: "Paiements instantanés",
    description: "Payez en ligne et en magasin avec votre carte Neo virtuelle ou physique. Transactions approuvées en moins d'une seconde."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>`,
    title: "Transferts internationaux",
    description: "Envoyez de l'argent dans plus de 50 pays avec des frais réduits et des taux de change transparents en temps réel."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>`,
    title: "Épargne intelligente",
    description: "Définissez vos objectifs d'épargne et laissez Neo automatiser vos économies avec des taux compétitifs."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Sécurité maximale",
    description: "Authentification biométrique, chiffrement de bout en bout et conformité aux normes bancaires les plus strictes."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/></svg>`,
    title: "App mobile intuitive",
    description: "Gérez vos finances depuis votre smartphone. Interface épurée, notifications en temps réel et contrôle total."
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
    title: "Neo Business",
    description: "Solutions sur mesure pour les entreprises : gestion de trésorerie, paiements fournisseurs et tableau de bord analytique."
  }
];

interface Props {
  variant?: 'default' | 'page';
}

const { variant = 'default' } = Astro.props;
const sectionPadding = variant === 'page' ? 'pt-8 pb-24' : 'py-24';
---

<section id="solutions" class:list={[sectionPadding, 'bg-neo-light']}>
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-semibold text-neo-secondary uppercase tracking-wider">Nos solutions</span>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-neo-black">
        Tout ce dont vous avez besoin, <span class="text-neo-primary">en une app</span>
      </h2>
      <p class="mt-4 text-neo-gray text-base md:text-lg">
        Des outils financiers pensés pour simplifier votre vie, que vous soyez particulier ou professionnel.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 border border-transparent hover:border-neo-secondary/30">
          <div class="w-14 h-14 bg-neo-primary/10 rounded-xl flex items-center justify-center text-neo-primary group-hover:bg-neo-primary group-hover:text-white transition-all duration-300">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="mt-6 text-lg font-bold text-neo-black">{feature.title}</h3>
          <p class="mt-3 text-neo-gray leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
