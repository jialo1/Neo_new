---
const testimonials = [
  {
    name: "Aminata Diallo",
    role: "Entrepreneuse",
    quote: "Neo a transformé la façon dont je gère les finances de mon entreprise. Les transferts internationaux sont rapides et les frais imbattables.",
    initials: "AD"
  },
  {
    name: "Mamadou Bah",
    role: "Développeur freelance",
    quote: "Recevoir mes paiements de clients internationaux n'a jamais été aussi simple. L'app est intuitive et le support client est excellent.",
    initials: "MB"
  },
  {
    name: "Fatoumata Keita",
    role: "Étudiante",
    quote: "L'outil d'épargne automatique m'aide à mettre de l'argent de côté sans y penser. En 6 mois, j'ai atteint mon objectif !",
    initials: "FK"
  }
];
---

<section class="py-24 bg-neo-light">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-sm font-semibold text-neo-secondary uppercase tracking-wider">Témoignages</span>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-neo-black">
        Ils ont choisi <span class="text-neo-primary">Neo</span>
      </h2>
      <p class="mt-4 text-neo-gray text-base md:text-lg">
        Découvrez pourquoi des milliers de personnes font confiance à Neo pour leurs finances.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-neo-light hover:shadow-lg transition-shadow duration-300">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-neo-black leading-relaxed italic">"{t.quote}"</p>
          <div class="mt-6 flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-br from-neo-primary to-neo-secondary rounded-full flex items-center justify-center text-white text-sm font-bold">
              {t.initials}
            </div>
            <div>
              <p class="font-semibold text-neo-black text-sm">{t.name}</p>
              <p class="text-neo-gray text-sm">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
