<section id="contact" class="py-16 md:py-20 bg-white">
  <div class="max-w-7xl mx-auto px-6">
    <div class="relative bg-gradient-to-br from-neo-primary to-neo-secondary rounded-2xl p-8 md:p-12 lg:p-14 text-center overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/5 rounded-full blur-2xl"></div>

      <div class="relative z-10 max-w-xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-white leading-snug">
          Prêt à rejoindre la révolution Neo ?
        </h2>
        <p class="mt-4 text-white/85 text-sm md:text-base leading-relaxed">
          Ouvrez votre compte en quelques minutes et découvrez une nouvelle façon de gérer votre argent. Aucun frais d'ouverture.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 sm:gap-3">
          <a href="#" class="group px-6 py-3 text-sm bg-white text-neo-primary font-semibold rounded-full hover:bg-neo-light transition-colors shadow-md">
            Créer mon compte gratuit
            <span class="inline-block ml-1.5 group-hover:translate-x-0.5 transition-transform">&rarr;</span>
          </a>
          <a href="#" class="px-6 py-3 text-sm border border-white/40 text-white font-semibold rounded-full hover:bg-white/10 transition-colors">
            Contacter l'équipe
          </a>
        </div>

        <p class="mt-5 text-white/55 text-xs md:text-sm leading-relaxed">
          Pas de carte bancaire requise &bull; Inscription en 3 minutes &bull; Annulation à tout moment
        </p>
      </div>
    </div>
  </div>
</section>
