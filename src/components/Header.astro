---
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-neo-light">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <img src="/images/neo-logo.png" alt="Neo" class="h-8" />
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-neo-black">
      <li><a href="/a-propos" class="hover:text-neo-primary transition-colors">À propos</a></li>
      <li><a href="/solutions" class="hover:text-neo-primary transition-colors">Fonctionnalités</a></li>
      <li><a href="/tarifs" class="hover:text-neo-primary transition-colors">Tarifs</a></li>
      <li><a href="/securite" class="hover:text-neo-primary transition-colors">Sécurité</a></li>
      <li><a href="/comment-ca-marche" class="hover:text-neo-primary transition-colors">Comment ça marche</a></li>
    </ul>

    <button id="mobile-menu-btn" class="md:hidden p-2 text-neo-black" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-neo-light">
    <div class="px-6 py-4 flex flex-col gap-4">
      <a href="/a-propos" class="text-sm font-medium text-neo-black hover:text-neo-primary transition-colors">À propos</a>
      <a href="/solutions" class="text-sm font-medium text-neo-black hover:text-neo-primary transition-colors">Fonctionnalités</a>
      <a href="/tarifs" class="text-sm font-medium text-neo-black hover:text-neo-primary transition-colors">Tarifs</a>
      <a href="/securite" class="text-sm font-medium text-neo-black hover:text-neo-primary transition-colors">Sécurité</a>
      <a href="/comment-ca-marche" class="text-sm font-medium text-neo-black hover:text-neo-primary transition-colors">Comment ça marche</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
