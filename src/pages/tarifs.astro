---
import Layout from '../layouts/Layout.astro';
import PageHeading from '../components/PageHeading.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';

const plans = [
  {
    name: "Free",
    audience: "Nouvel utilisateur",
    price: "0",
    features: [
      "Compte Neo gratuit",
      "Transferts entre comptes Neo",
      "Carte virtuelle basique",
      "Paiement de factures",
      "Historique de transactions",
      "Notifications en temps réel",
      "Support communautaire"
    ],
    cta: "Commencer gratuitement",
    highlighted: false
  },
  {
    name: "Premium",
    audience: "Expert",
    price: "2 990",
    features: [
      "Tout ce qui est dans Free",
      "Carte virtuelle premium",
      "Transferts internationaux",
      "Analyse avancée des données",
      "Limites de transaction élevées",
      "Support prioritaire 24h/24",
      "Tap to Pay sans contact"
    ],
    cta: "Passer à Premium",
    highlighted: true
  }
];
---

<Layout
  title="Tarifs — Neo"
  description="Choisissez l'expérience qui vous correspond. Deux niveaux d'accès conçus pour répondre à vos besoins."
>
  <PageHeading
    title="Tarifs"
    description="Trois niveaux d'accès, chacun conçu pour répondre à des besoins différents avec la même exigence de qualité."
    tone="white"
  />

  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="text-sm font-semibold text-neo-secondary uppercase tracking-wider">Un modèle pensé pour l'excellence</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold text-neo-black">
          Choisissez l'expérience qui vous <span class="text-neo-primary">correspond</span>
        </h2>
        <p class="mt-4 text-neo-gray text-base md:text-lg">
          Une structure de coûts alignée avec une expérience premium.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {plans.map((plan) => (
          <div class:list={[
            'rounded-2xl p-8 border transition-shadow duration-300',
            plan.highlighted
              ? 'bg-gradient-to-b from-neo-primary to-neo-secondary text-white border-transparent shadow-xl shadow-neo-primary/20'
              : 'bg-white border-neo-light hover:shadow-lg'
          ]}>
            <div class="flex items-center justify-between mb-6">
              <div>
                <h3 class:list={['text-xl font-bold', plan.highlighted ? 'text-white' : 'text-neo-black']}>
                  {plan.name}
                </h3>
                <p class:list={['text-sm mt-0.5', plan.highlighted ? 'text-white/70' : 'text-neo-gray']}>
                  {plan.audience}
                </p>
              </div>
              {plan.highlighted && (
                <span class="px-3 py-1 bg-white/20 text-white text-xs font-semibold rounded-full">Populaire</span>
              )}
            </div>

            <div class="mb-6">
              <span class:list={['text-4xl font-bold', plan.highlighted ? 'text-white' : 'text-neo-black']}>
                {plan.price} F
              </span>
              <span class:list={['text-sm', plan.highlighted ? 'text-white/70' : 'text-neo-gray']}> /mois</span>
            </div>

            <ul class="space-y-3 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2.5">
                  <svg class:list={['w-4 h-4 mt-0.5 shrink-0', plan.highlighted ? 'text-white' : 'text-neo-secondary']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                  </svg>
                  <span class:list={['text-sm', plan.highlighted ? 'text-white/90' : 'text-neo-gray']}>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href="#"
              class:list={[
                'block text-center px-6 py-3 text-sm font-semibold rounded-full transition-colors',
                plan.highlighted
                  ? 'bg-white text-neo-primary hover:bg-neo-light'
                  : 'bg-neo-primary text-white hover:bg-neo-secondary'
              ]}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ />
  <CTA />
</Layout>
